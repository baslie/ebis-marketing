---
const logos = Array.from({ length: 9 }, (_, i) => i + 1);
---

<section class="py-4 md:py-6">
  <div class="max-w-7xl mx-auto px-4">
    <p class="text-xs text-text-muted text-center mb-3">Наши партнёры</p>
    <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-9 gap-3">
      {logos.map((n) => (
        <div class="bg-white rounded-sm aspect-video flex items-center justify-center text-text-muted text-xs border border-gray-300">
          {n}
        </div>
      ))}
    </div>
  </div>
</section>
